# Copy this file to .env and fill in your values before running docker-compose.

# Required: Your OpenWeatherMap API key
# Get one free at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# MongoDB connection string (local or Atlas)
# Local:  MONGODB_URL=mongodb://localhost:27017
# Atlas:  MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=weather_app

# Comma-separated list of origins allowed to call the backend
# Add your deployed frontend URL here when hosting
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# Optional (docker-compose sets this automatically)
# BACKEND_URL=http://localhost:8000
